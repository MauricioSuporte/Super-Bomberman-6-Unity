  titleSceneName: TitleScreen
  worldCompleteLabel: <size=52><color=#1ABC00>WORLD 2</color>  <color=#E8E8E8>DEMO
    COMPLETE!</color></size>
  openSourceBlock: '<size=32><color=#3392FF>OPEN SOURCE PROJECT</color></size>

    <size=28><color=#E8E8E8>github.com/MauricioSuporte/</color></size>

